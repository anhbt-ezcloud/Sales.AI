<style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-background text-on-surface overflow-hidden">
<div class="flex h-screen w-full">
<!-- PANEL A: SIDEBAR (Source: SideNavBar JSON) -->
<aside class="h-screen w-[240px] fixed left-0 top-0 bg-[#eff4ff] dark:bg-[#1e293b] flex flex-col h-full py-4 z-50">
<!-- Brand -->
<div class="px-6 mb-8">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-[#3525cd] text-3xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
<div>
<h1 class="text-lg font-semibold text-[#3525cd] dark:text-[#4f46e5]">Concierge AI</h1>
<p class="text-[0.65rem] uppercase tracking-wider text-outline font-bold">Gói Doanh nghiệp</p>
</div>
</div>
</div>
<!-- Nav Tabs -->
<nav class="flex-1 space-y-1">
<a class="flex items-center px-4 py-2 bg-[#4f46e5] text-white rounded-md mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">chat_bubble</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">Chat tài liệu</span>
</a>
<a class="flex items-center px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">group</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">CRM &amp; Công việc</span>
</a>
<a class="flex items-center px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">assignment</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">Dự án</span>
</a>
<a class="flex items-center px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">analytics</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">Báo cáo</span>
</a>
<a class="flex items-center px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">settings</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">Cài đặt</span>
</a>
</nav>
<!-- CTA -->
<div class="mx-4 my-6 p-4 rounded-xl bg-primary-container/10 border border-primary-container/20">
<p class="text-xs text-primary mb-2 font-medium">Tối ưu hóa quy trình</p>
<button class="w-full py-2 bg-primary text-white text-xs font-semibold rounded-lg hover:opacity-90 transition-all active:scale-95">Nâng cấp ngay</button>
</div>
<!-- Footer Tabs -->
<div class="pt-4 border-t border-outline-variant/20">
<a class="flex items-center px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-200/50 mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">help</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">Trợ giúp</span>
</a>
<a class="flex items-center px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-200/50 mx-2 transition-colors duration-200" href="#">
<span class="material-symbols-outlined mr-3">logout</span>
<span class="font-inter text-[0.875rem] leading-[1.6]">Đăng xuất</span>
</a>
</div>
</aside>
<!-- MAIN CANVAS -->
<main class="ml-[240px] flex-1 flex overflow-hidden">
<!-- PANEL B: CHAT HISTORY (320px) -->
<section class="w-[320px] bg-surface-container-low flex flex-col border-r border-outline-variant/10">
<div class="p-4 space-y-4">
<button class="w-full flex items-center justify-center gap-2 py-3 bg-primary-container text-white rounded-xl font-semibold shadow-lg shadow-primary-container/20 hover:scale-[1.02] active:scale-95 transition-all">
<span class="material-symbols-outlined">add</span>
                        Cuộc chat mới
                    </button>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
<input class="w-full bg-surface-container-lowest border-none rounded-xl pl-10 text-sm focus:ring-2 focus:ring-primary/20 placeholder:text-outline/60" placeholder="Tìm kiếm hội thoại..." type="text"/>
</div>
<div class="flex gap-1 p-1 bg-surface-container rounded-lg overflow-x-auto scrollbar-hide">
<button class="px-3 py-1.5 text-xs font-semibold bg-white rounded-md shadow-sm">Tất cả</button>
<button class="px-3 py-1.5 text-xs font-medium text-outline hover:text-primary transition-colors">Của tôi</button>
<button class="px-3 py-1.5 text-xs font-medium text-outline hover:text-primary transition-colors whitespace-nowrap">Team chia sẻ</button>
</div>
<button class="w-full flex items-center gap-3 px-4 py-2.5 bg-secondary-container/20 text-on-secondary-container rounded-xl border border-secondary-container/30 hover:bg-secondary-container/30 transition-all">
<span class="material-symbols-outlined text-secondary">library_books</span>
<span class="text-xs font-bold uppercase tracking-wider">📚 Thư viện tài liệu</span>
</button>
</div>
<div class="flex-1 overflow-y-auto px-2 space-y-6 pb-6">
<!-- Group Today -->
<div>
<h3 class="px-4 text-[0.6875rem] font-bold text-outline uppercase tracking-widest mb-3">Hôm nay</h3>
<div class="space-y-1">
<div class="group relative bg-surface-container-lowest p-3 rounded-xl cursor-pointer border border-transparent hover:border-primary-container/20 transition-all shadow-sm">
<div class="flex justify-between items-start mb-1">
<h4 class="text-sm font-semibold text-on-surface truncate pr-4">Phân tích hợp đồng A</h4>
<div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
</div>
<p class="text-xs text-outline line-clamp-1 mb-2">Kiểm tra các điều khoản về thanh toán...</p>
<div class="flex items-center -space-x-2">
<span class="material-symbols-outlined text-xs p-1 bg-surface-container rounded-full text-primary border border-white">description</span>
<span class="material-symbols-outlined text-xs p-1 bg-surface-container rounded-full text-primary border border-white">analytics</span>
</div>
</div>
<div class="group p-3 rounded-xl cursor-pointer hover:bg-surface-container transition-all">
<h4 class="text-sm font-medium text-on-surface truncate">Báo giá Premium 2026</h4>
<p class="text-xs text-outline line-clamp-1">Thông tin chi tiết về các gói ưu đãi...</p>
</div>
</div>
</div>
<!-- Group Yesterday -->
<div>
<h3 class="px-4 text-[0.6875rem] font-bold text-outline uppercase tracking-widest mb-3">Hôm qua</h3>
<div class="space-y-1 opacity-80">
<div class="group p-3 rounded-xl cursor-pointer hover:bg-surface-container transition-all">
<h4 class="text-sm font-medium text-on-surface truncate">Quy trình vận hành 2.0</h4>
<p class="text-xs text-outline line-clamp-1">Tài liệu hướng dẫn triển khai...</p>
</div>
<div class="group p-3 rounded-xl cursor-pointer hover:bg-surface-container transition-all">
<h4 class="text-sm font-medium text-on-surface truncate">Kế hoạch Marketing Q4</h4>
<p class="text-xs text-outline line-clamp-1">Bản thảo chiến dịch cuối năm...</p>
</div>
</div>
</div>
</div>
</section>
<!-- PANEL C: MAIN CHAT AREA -->
<section class="flex-1 flex flex-col bg-surface-bright relative">
<!-- Chat Header -->
<header class="h-16 flex items-center justify-between px-6 bg-white/80 backdrop-blur-[15px] sticky top-0 z-10 border-b border-outline-variant/5">
<div class="flex items-center gap-4">
<div class="flex flex-col">
<div class="flex items-center gap-2">
<h2 class="font-bold text-on-surface">Phân tích Báo giá 2026</h2>
<span class="material-symbols-outlined text-sm text-outline cursor-pointer hover:text-primary">edit</span>
</div>
<div class="flex items-center gap-1.5">
<div class="w-2 h-2 rounded-full bg-secondary"></div>
<span class="text-[10px] font-bold text-secondary uppercase tracking-tighter">🟢 AI sẵn sàng</span>
</div>
</div>
<div class="h-6 w-px bg-outline-variant/30"></div>
<div class="flex gap-2">
<div class="flex items-center gap-1.5 px-2.5 py-1 bg-surface-container-low rounded-full border border-primary-container/10">
<span class="material-symbols-outlined text-sm text-primary">picture_as_pdf</span>
<span class="text-[11px] font-medium text-on-surface">BaoGia_2026.pdf</span>
</div>
<div class="flex items-center gap-1.5 px-2.5 py-1 bg-surface-container-low rounded-full border border-primary-container/10">
<span class="material-symbols-outlined text-sm text-secondary">table_chart</span>
<span class="text-[11px] font-medium text-on-surface">SanPham.xlsx</span>
</div>
</div>
</div>
<div class="flex items-center gap-2">
<button class="p-2 hover:bg-surface-container rounded-full transition-colors">
<span class="material-symbols-outlined text-outline">share</span>
</button>
<button class="p-2 hover:bg-surface-container rounded-full transition-colors">
<span class="material-symbols-outlined text-outline">ios_share</span>
</button>
</div>
</header>
<!-- Messages Area -->
<div class="flex-1 overflow-y-auto p-8 space-y-8 scrollbar-hide">
<!-- User Message -->
<div class="flex justify-end">
<div class="max-w-[70%] bg-primary-container text-white px-5 py-3 rounded-2xl rounded-tr-none shadow-md shadow-primary-container/10">
<p class="body-md leading-relaxed">Giá gói Premium cho khách 50 user là bao nhiêu?</p>
</div>
</div>
<!-- Bot Message -->
<div class="flex justify-start gap-4">
<div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center shrink-0">
<span class="material-symbols-outlined text-white text-sm" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
</div>
<div class="max-w-[80%] space-y-4">
<div class="bg-white border border-outline-variant/10 p-5 rounded-2xl rounded-tl-none shadow-sm space-y-3">
<p class="body-md text-on-surface leading-relaxed">
                                    Theo bảng giá trong <strong class="text-primary">BaoGia_2026.pdf</strong> trang 12, gói Premium cho 50 user có giá <strong class="text-on-surface font-bold">39 USD/user/tháng</strong>, tổng <strong class="text-on-surface font-bold">1,950 USD/tháng</strong>. 
                                </p>
<p class="body-md text-on-surface leading-relaxed">
                                    Khi mua hợp đồng 12 tháng được giảm <strong class="text-secondary font-bold">15%</strong> trên tổng hóa đơn. Bạn có muốn tôi tính toán tổng chi phí sau khi giảm cho 1 năm không?
                                </p>
</div>
<!-- CITATIONS CARD -->
<div class="bg-surface-container-low rounded-xl p-4 border border-outline-variant/10">
<div class="flex items-center gap-2 mb-3">
<span class="material-symbols-outlined text-primary text-sm">menu_book</span>
<span class="text-[0.6875rem] font-bold uppercase tracking-widest text-outline">Nguồn trích dẫn (2)</span>
</div>
<div class="space-y-2">
<a class="flex items-center justify-between group" href="#">
<div class="flex items-center gap-2">
<span class="w-1.5 h-1.5 rounded-full bg-primary-container"></span>
<span class="text-xs text-primary font-medium group-hover:underline">BaoGia_2026.pdf</span>
</div>
<span class="text-[10px] text-outline font-medium">Trang 12</span>
</a>
</div>
</div>
<!-- Feedback Row -->
<div class="flex items-center gap-4 text-outline px-1">
<button class="hover:text-primary transition-colors"><span class="material-symbols-outlined text-lg">thumb_up</span></button>
<button class="hover:text-error transition-colors"><span class="material-symbols-outlined text-lg">thumb_down</span></button>
<button class="hover:text-primary transition-colors"><span class="material-symbols-outlined text-lg">content_copy</span></button>
<button class="hover:text-primary transition-colors"><span class="material-symbols-outlined text-lg">refresh</span></button>
</div>
</div>
</div>
<!-- Typing indicator -->
<div class="flex items-center gap-3 px-12">
<div class="flex gap-1 px-3 py-2 bg-surface-container-low rounded-full w-fit">
<span class="w-1.5 h-1.5 bg-outline-variant rounded-full animate-bounce"></span>
<span class="w-1.5 h-1.5 bg-outline-variant rounded-full animate-bounce [animation-delay:0.2s]"></span>
<span class="w-1.5 h-1.5 bg-outline-variant rounded-full animate-bounce [animation-delay:0.4s]"></span>
</div>
</div>
</div>
<!-- Chat Input Section -->
<div class="px-6 py-4 bg-white border-t border-outline-variant/5">
<div class="max-w-4xl mx-auto space-y-4">
<!-- Prompt chips -->
<div class="flex gap-2 overflow-x-auto scrollbar-hide">
<button class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-container text-xs font-semibold rounded-full hover:bg-primary-container/10 hover:text-primary transition-all border border-transparent hover:border-primary-container/20">
<span class="material-symbols-outlined text-sm">description</span>
                                Tóm tắt tài liệu
                            </button>
<button class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-container text-xs font-semibold rounded-full hover:bg-primary-container/10 hover:text-primary transition-all border border-transparent hover:border-primary-container/20">
<span class="material-symbols-outlined text-sm">star</span>
                                Điểm chính
                            </button>
<button class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-container text-xs font-semibold rounded-full hover:bg-primary-container/10 hover:text-primary transition-all border border-transparent hover:border-primary-container/20">
<span class="material-symbols-outlined text-sm">equalizer</span>
                                Trích xuất số liệu
                            </button>
</div>
<!-- Input container -->
<div class="relative bg-surface-container-lowest rounded-2xl border-2 border-outline-variant/10 focus-within:border-primary/20 focus-within:ring-4 focus-within:ring-primary/5 transition-all p-2">
<div class="flex items-end gap-2 px-2 py-1">
<button class="p-2 text-outline hover:text-primary transition-colors rounded-lg hover:bg-surface-container">
<span class="material-symbols-outlined">attach_file</span>
</button>
<textarea class="flex-1 border-none focus:ring-0 resize-none bg-transparent py-2 text-sm max-h-32 scrollbar-hide" placeholder="Hỏi bất cứ điều gì về tài liệu..." rows="1"></textarea>
<button class="bg-primary text-white p-2.5 rounded-xl hover:shadow-lg hover:shadow-primary/30 active:scale-95 transition-all">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
</button>
</div>
</div>
<!-- Footer disclaimer -->
<p class="text-center text-[10px] text-outline font-medium">AI có thể sai. Hãy kiểm tra trích dẫn nguồn.</p>
</div>
</div>
</section>
</main>
</div>
</body></html>